#!/usr/bin/env bash
# rheniite: wire installed Flatpak browsers up to the native 1Password app.
#
# 1Password officially doesn't support Flatpak browsers. The host-side pieces
# are baked into the image (BrowserSupport is setgid, and "flatpak-session-helper"
# is in /etc/1password/custom_allowed_browsers). The remaining pieces are per-user
# and live in $HOME, so they can't be baked into /usr — this runs them at login.
#
# For every installed Flatpak browser it drops, into that browser's sandbox dir:
#   * a wrapper that runs `flatpak-spawn --host /usr/libexec/1Password-BrowserSupport`
#     (a sandboxed browser can't exec the host helper directly)
#   * a com.1password.1password native-messaging manifest pointing at the wrapper
#   * a --talk-name=org.freedesktop.Flatpak override so the wrapper can reach the host
#
# Idempotent; safe to re-run every login. Run as: systemd --user oneshot.
set -euo pipefail

HELPER=/usr/libexec/1Password-BrowserSupport
if [[ ! -x "$HELPER" ]]; then
    echo "1password-flatpak-setup: $HELPER not present; nothing to do"
    exit 0
fi
if ! command -v flatpak >/dev/null 2>&1; then
    echo "1password-flatpak-setup: flatpak not available; nothing to do"
    exit 0
fi

# app-id | family (ff|chromium) | native-messaging-host dir as seen INSIDE the
# sandbox (i.e. $HOME-relative). Extend this list for other browsers as needed.
browsers=(
    "org.mozilla.firefox|ff|.mozilla/native-messaging-hosts"
    "io.gitlab.librewolf-community|ff|.librewolf/native-messaging-hosts"
    "app.zen_browser.zen|ff|.zen/native-messaging-hosts"
    "one.ablaze.floorp|ff|.floorp/native-messaging-hosts"
    "net.waterfox.waterfox|ff|.waterfox/native-messaging-hosts"
    "com.google.Chrome|chromium|.config/google-chrome/NativeMessagingHosts"
    "com.google.ChromeDev|chromium|.config/google-chrome-unstable/NativeMessagingHosts"
    "com.brave.Browser|chromium|.config/BraveSoftware/Brave-Browser/NativeMessagingHosts"
    "org.chromium.Chromium|chromium|.config/chromium/NativeMessagingHosts"
    "com.microsoft.Edge|chromium|.config/microsoft-edge/NativeMessagingHosts"
    "com.vivaldi.Vivaldi|chromium|.config/vivaldi/NativeMessagingHosts"
    "com.opera.Opera|chromium|.config/opera/NativeMessagingHosts"
)

# Map a sandbox $HOME-relative path to its real location under ~/.var/app/<id>/.
# Flatpak stores the XDG dirs under config/ data/ cache/, other dotdirs verbatim.
host_subpath() {
    local rel="$1"
    case "$rel" in
        .config/*)      echo "config/${rel#.config/}" ;;
        .local/share/*) echo "data/${rel#.local/share/}" ;;
        .cache/*)       echo "cache/${rel#.cache/}" ;;
        *)              echo "$rel" ;;
    esac
}

# Native-messaging manifests. If 1Password ships one on the host we reuse it
# (authoritative extension IDs) and only repoint `path`; otherwise fall back to
# the well-known IDs below. Firefox matches by extension id; Chromium by origin.
FF_TEMPLATE=""
for p in /usr/lib/mozilla/native-messaging-hosts/com.1password.1password.json \
         /usr/lib64/mozilla/native-messaging-hosts/com.1password.1password.json; do
    [[ -f "$p" ]] && FF_TEMPLATE="$p" && break
done
CH_TEMPLATE=""
for p in /etc/opt/chrome/native-messaging-hosts/com.1password.1password.json \
         /etc/chromium/native-messaging-hosts/com.1password.1password.json \
         /usr/lib/chromium/native-messaging-hosts/com.1password.1password.json; do
    [[ -f "$p" ]] && CH_TEMPLATE="$p" && break
done

write_manifest() {  # $1 family  $2 in-sandbox wrapper path  $3 dest file
    local family="$1" wrapper="$2" dest="$3" template=""
    [[ "$family" == ff ]] && template="$FF_TEMPLATE" || template="$CH_TEMPLATE"

    if [[ -n "$template" ]] && command -v python3 >/dev/null 2>&1; then
        python3 - "$template" "$wrapper" "$dest" <<'PY'
import json, sys
src, wrapper, dst = sys.argv[1:4]
with open(src) as f:
    m = json.load(f)
m["path"] = wrapper
with open(dst, "w") as f:
    json.dump(m, f, indent=2)
    f.write("\n")
PY
        return
    fi

    if [[ "$family" == ff ]]; then
        cat >"$dest" <<JSON
{
    "name": "com.1password.1password",
    "description": "1Password BrowserSupport",
    "path": "$wrapper",
    "type": "stdio",
    "allowed_extensions": ["{d634138d-c276-4fc8-924b-40a0ea21d284}"]
}
JSON
    else
        cat >"$dest" <<JSON
{
    "name": "com.1password.1password",
    "description": "1Password BrowserSupport",
    "path": "$wrapper",
    "type": "stdio",
    "allowed_origins": [
        "chrome-extension://aeblfdkhhhdcdjpifhhbdiojplfjncoa/",
        "chrome-extension://gejiddohjgmkcmehoncgpeapfphapdmk/",
        "chrome-extension://dppgmdbiimibapkepcbdbmkaabgiofem/",
        "chrome-extension://khgocmkkpikpnmmkgmdnfckapcdkgfaf/"
    ]
}
JSON
    fi
}

count=0
for entry in "${browsers[@]}"; do
    IFS='|' read -r appid family sandbox_rel <<<"$entry"
    flatpak info "$appid" >/dev/null 2>&1 || continue

    hostdir="$HOME/.var/app/$appid/$(host_subpath "$sandbox_rel")"
    mkdir -p "$hostdir"

    # Wrapper on disk (host path); the browser sees it at the in-sandbox path.
    cat >"$hostdir/1password-browsersupport-wrapper.sh" <<'WRAP'
#!/usr/bin/env bash
exec flatpak-spawn --host /usr/libexec/1Password-BrowserSupport "$@"
WRAP
    chmod 0755 "$hostdir/1password-browsersupport-wrapper.sh"

    # The manifest `path` must be the IN-SANDBOX path: flatpak bind-mounts the
    # per-app dir at $HOME, and preserves the $HOME string, so this resolves.
    write_manifest "$family" \
        "$HOME/$sandbox_rel/1password-browsersupport-wrapper.sh" \
        "$hostdir/com.1password.1password.json"

    # flatpak-spawn --host reaches the host over the org.freedesktop.Flatpak name.
    flatpak override --user --talk-name=org.freedesktop.Flatpak "$appid" 2>/dev/null || true

    echo "1password-flatpak-setup: configured $appid"
    count=$((count + 1))
done

echo "1password-flatpak-setup: $count Flatpak browser(s) configured"
